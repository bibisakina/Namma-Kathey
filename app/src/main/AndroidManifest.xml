<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <queries>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="geo" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="https" />
        </intent>
    </queries>

    <application
        android:name=".NammaKatheyApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.NammaKathey"
        tools:targetApi="31">
        
        <activity
            android:name=".ui.auth.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.NammaKathey.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.auth.LoginActivity"
            android:exported="false"
            android:theme="@style/Theme.NammaKathey.NoActionBar"/>

        <activity
            android:name=".ui.auth.RegisterActivity"
            android:exported="false"
            android:theme="@style/Theme.NammaKathey.NoActionBar"/>

        <activity
            android:name=".ui.main.MainActivity"
            android:exported="false"
            android:theme="@style/Theme.NammaKathey.NoActionBar"/>
            
        <activity
            android:name=".ui.hero.HeroListActivity"
            android:exported="false"
            android:theme="@style/Theme.NammaKathey.NoActionBar"/>

        <activity
            android:name=".ui.hero.HeroDetailActivity"
            android:exported="false"
            android:theme="@style/Theme.NammaKathey.NoActionBar"/>

        <activity
            android:name=".ui.storybook.StorybookActivity"
            android:exported="false"
            android:theme="@style/Theme.NammaKathey.NoActionBar"/>

        <activity
            android:name=".ui.quiz.QuizActivity"
            android:exported="false"
            android:theme="@style/Theme.NammaKathey.NoActionBar"/>

    </application>

</manifest>
