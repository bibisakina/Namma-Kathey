    <!-- District Descriptions -->
    <string name="desc_d1">ಬಾದಾಮಿ ಗುಹೆಗಳು ಮತ್ತು ಪ್ರಾಚೀನ ದೇವಾಲಯಗಳಿಗೆ ಹೆಸರುವಾಸಿಯಾಗಿದೆ</string>
    <string name="desc_d2">ಕೋಟೆಗಳು ಮತ್ತು ಸ್ವಾತಂತ್ರ್ಯ ಚಳುವಳಿಯ ಇತಿಹಾಸಕ್ಕೆ ಹೆಸರುವಾಸಿಯಾಗಿದೆ</string>
    <string name="desc_d3">ಕರ್ನಾಟಕದ ಸಾಂಸ್ಕೃತಿಕ ಮತ್ತು ಐತಿಹಾಸಿಕ ಕೇಂದ್ರ</string>
    <string name="desc_d5">ರಾಜಧಾನಿ ಮತ್ತು ಮಾಹಿತಿ ತಂತ್ರಜ್ಞಾನ ಕೇಂದ್ರ</string>
    <string name="desc_d8">ನಂದಿ ಬೆಟ್ಟಗಳು ಮತ್ತು ಇತಿಹಾಸಕ್ಕೆ ಹೆಸರುವಾಸಿಯಾಗಿದೆ</string>
    <string name="desc_d22">ರಾಜ ಪರಂಪರೆ ಮತ್ತು ದಸರಾ ಹಬ್ಬಕ್ಕೆ ಹೆಸರುವಾಸಿಯಾಗಿದೆ</string>
    <string name="desc_d25">ನೈಸರ್ಗಿಕ ಸೌಂದರ್ಯ ಮತ್ತು ಐತಿಹಾಸಿಕ ಮಹತ್ವ</string>
    <string name="desc_d29">ಗೋಲ್ ಗುಂಬಜ್‌ಗೆ ಹೆಸರುವಾಸಿಯಾಗಿದೆ</string>
    <string name="desc_d13">ಶಿಕ್ಷಣ ಮತ್ತು ಸಾಹಿತ್ಯದ ಕೇಂದ್ರ</string>
    <string name="desc_d18">ಶ್ರೀಮಂತ ಸಂಪ್ರದಾಯಗಳನ್ನು ಹೊಂದಿರುವ ಕಾಫಿ ನಾಡು</string>
    <string name="desc_d11">ಕರಾವಳಿ ಸೌಂದರ್ಯ ಮತ್ತು ವೀರರ ಇತಿಹಾಸ</string>
    <string name="desc_d21">ಸಕ್ಕರೆ ನಾಡು ಮತ್ತು ಶ್ರೀಮಂತ ಸಂಸ್ಕೃತಿ</string>
